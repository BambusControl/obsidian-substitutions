{
    "$id": "https://raw.githubusercontent.com/BambusControl/obsidian-substitutions/0.6.0/resources/save-data-schema.json",
    "$schema": "http://json-schema.org/draft-07/schema#",
    "definitions": {
        "DataEvent": {
            "description": "An event, which communicates information between data parts"
        },
        "MetaFragment": {
            "description": "Meta information for the datastore",
            "properties": {
                "events": {
                    "description": "A collection of unique data events.",
                    "items": {
                        "$ref": "https://raw.githubusercontent.com/BambusControl/obsidian-substitutions/0.6.0/resources/save-data-schema.json#/definitions/DataEvent"
                    },
                    "type": "array"
                },
                "initialized": {
                    "type": "boolean"
                },
                "pluginVersion": {
                    "$ref": "https://raw.githubusercontent.com/BambusControl/obsidian-substitutions/0.6.0/resources/save-data-schema.json#/definitions/PluginVersion",
                    "description": "Latest used version of the plugin which used this data"
                },
                "version": {
                    "$ref": "https://raw.githubusercontent.com/BambusControl/obsidian-substitutions/0.6.0/resources/save-data-schema.json#/definitions/SaveDataVersion"
                }
            },
            "required": [
                "events",
                "initialized",
                "pluginVersion",
                "version"
            ],
            "type": "object"
        },
        "PluginVersion": {
            "description": "Version of the plugin.\n\nMust comply with RegEx:\n```^[0-9]+\\\\.[0-9]+\\\\.[0-9]+(?:-[A-Z]+)?$```",
            "enum": [
                "0.1.0",
                "0.1.1",
                "0.1.2",
                "0.2.0",
                "0.3.0",
                "0.3.1",
                "0.4.0",
                "0.4.1",
                "0.4.2",
                "0.5.0",
                "0.6.0"
            ],
            "type": "string"
        },
        "SaveDataVersion": {
            "description": "Version of the save data schema.\n\nMust comply with RegEx:\n```^[0-9]+\\\\.[0-9]+\\\\.[0-9]+(?:-[A-Z]+)?$```\n\nThe version of the save data schema is independent of the plugin version",
            "enum": [
                "0.1.0",
                "0.5.0"
            ],
            "type": "string"
        },
        "SavedSwapDefinition": {
            "properties": {
                "enabled": {
                    "type": "boolean"
                },
                "id": {
                    "type": "number"
                },
                "kind": {
                    "$ref": "https://raw.githubusercontent.com/BambusControl/obsidian-substitutions/0.6.0/resources/save-data-schema.json#/definitions/SwapKind"
                },
                "replacement": {
                    "type": "string"
                },
                "source": {
                    "type": "string"
                }
            },
            "required": [
                "enabled",
                "id",
                "kind",
                "replacement",
                "source"
            ],
            "type": "object"
        },
        "SwapKind": {
            "enum": [
                "plain",
                "regex"
            ],
            "type": "string"
        },
        "UserSwapFragment": {
            "description": "User saved swap definitions",
            "properties": {
                "definitions": {
                    "description": "Definitions of swaps",
                    "items": {
                        "$ref": "https://raw.githubusercontent.com/BambusControl/obsidian-substitutions/0.6.0/resources/save-data-schema.json#/definitions/SavedSwapDefinition"
                    },
                    "type": "array"
                },
                "initialized": {
                    "type": "boolean"
                },
                "version": {
                    "$ref": "https://raw.githubusercontent.com/BambusControl/obsidian-substitutions/0.6.0/resources/save-data-schema.json#/definitions/SaveDataVersion"
                }
            },
            "required": [
                "definitions",
                "initialized",
                "version"
            ],
            "type": "object"
        }
    },
    "description": "Structure of `data.json`, where each fragment is a self-managed data fragment",
    "properties": {
        "meta": {
            "$ref": "https://raw.githubusercontent.com/BambusControl/obsidian-substitutions/0.6.0/resources/save-data-schema.json#/definitions/MetaFragment"
        },
        "swap": {
            "$ref": "https://raw.githubusercontent.com/BambusControl/obsidian-substitutions/0.6.0/resources/save-data-schema.json#/definitions/UserSwapFragment"
        }
    },
    "required": [
        "meta",
        "swap"
    ],
    "type": "object"
}

